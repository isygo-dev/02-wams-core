<!DOCTYPE html>
<html dir="ltr" xmlns="http://www.w3.org/1999/xhtml"
      lang="en">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1" name="viewport">
    <meta name="x-apple-disable-message-reformatting">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta content="telephone=no" name="format-detection">
    <title>Your account was created</title>
    <!--[if gte mso 9]>
    <xml>
        <o:OfficeDocumentSettings>
            <o:AllowPNG></o:AllowPNG>
            <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
    </xml>
    <![endif]-->
    <style type="text/css">
        body, table, td {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            width: 100% !important;
            height: 100% !important;
            padding: 0;
            margin: 0;
            background-color: #F4F5F7;
        }

        table {
            border-collapse: collapse;
        }

        a {
            color: #0C66E4;
        }

        .cred {
            font-family: 'Courier New', Courier, monospace;
        }

        @media only screen and (max-width: 600px) {
            .wrap {
                width: 100% !important;
            }

            .pad {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }
        }
    </style>
</head>
<body style="width:100%;height:100%;padding:0;margin:0;background-color:#F4F5F7">
<div style="display:none;max-height:0;overflow:hidden;opacity:0">
    Your account is ready — here's how to sign in for the first time. &#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;&#8203;
</div>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F4F5F7">
    <tr>
        <td align="center" style="padding:24px 12px">
            <table role="presentation" class="wrap" width="600" cellpadding="0" cellspacing="0"
                   style="width:600px;max-width:600px">

                <!-- Brand header -->
                <tr>
                    <td align="center" style="padding-bottom:16px">
                        <a href="${V_TENANT_URL!"#"}" target="_blank" style="text-decoration:none">
                            <img src="https://isygo-it.eu/assets/images/logo.png" width="140" alt="Logo"
                                 style="display:block;border:0;outline:none;text-decoration:none">
                        </a>
                    </td>
                </tr>

                <!-- Content card -->
                <tr>
                    <td class="pad"
                        style="background-color:#FFFFFF;border:1px solid #DFE1E6;border-radius:8px;padding:40px">

                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td align="center" style="padding-bottom:20px">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="64" height="64"
                                           style="width:64px;height:64px;background-color:#DFFCEC;border-radius:32px">
                                        <tr>
                                            <td align="center" valign="middle">
                                                <svg width="27" height="27" viewBox="0 0 24 24" fill="none"
                                                     xmlns="http://www.w3.org/2000/svg" role="img"
                                                     aria-label="Account created">
                                                    <circle cx="10" cy="8" r="3.5" stroke="#1F845A" stroke-width="1.6"/>
                                                    <path d="M4 20c0-3.5 2.7-6 6-6 1 0 1.9.2 2.7.6" stroke="#1F845A"
                                                          stroke-width="1.6" stroke-linecap="round"/>
                                                    <path d="m15 15.5 2 2 3.5-3.8" stroke="#1F845A" stroke-width="1.7"
                                                          stroke-linecap="round" stroke-linejoin="round"/>
                                                </svg>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style="padding-bottom:12px">
                                    <h1 style="margin:0;font-size:22px;line-height:28px;font-weight:600;color:#172B4D">
                                        Your account was created</h1>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding-bottom:20px;font-size:15px;line-height:23px;color:#44546F">
                                    Hi ${V_FULLNAME},<br><br>
                                    Welcome aboard! Your account has been created successfully. Here are your sign-in
                                    credentials:
                                </td>
                            </tr>
                            <tr>
                                <td style="padding-bottom:24px">
                                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                                           style="background-color:#F4F5F7;border:1px solid #DFE1E6;border-radius:8px">
                                        <tr>
                                            <td style="padding:16px 20px">
                                                <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                                                    <tr>
                                                        <td style="font-size:12px;color:#8590A2;text-transform:uppercase;letter-spacing:.03em;padding-bottom:2px">
                                                            Login
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="cred"
                                                            style="font-size:15px;color:#172B4D;padding-bottom:12px">${V_USER_NAME}</td>
                                                    </tr>
                                                    <tr>
                                                        <td style="font-size:12px;color:#8590A2;text-transform:uppercase;letter-spacing:.03em;padding-bottom:2px">
                                                            Temporary password
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td class="cred"
                                                            style="font-size:15px;color:#172B4D">${V_PASSWORD}</td>
                                                    </tr>
                                                </table>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding-bottom:24px;font-size:14px;line-height:21px;color:#626F86">
                                    For your security, we recommend changing this password the first time you sign in.
                                </td>
                            </tr>
                            <tr>
                                <td align="center">
                                    <!--[if mso]>
                                    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="${V_GATEWAY_URL}" style="height:44px;v-text-anchor:middle;width:280px" arcsize="10%" stroke="f" fillcolor="#0C66E4">
                                        <w:anchorlock></w:anchorlock>
                                        <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:15px;font-weight:600">Partner relationship management gateway</center>
                                    </v:roundrect>
                                    <![endif]-->
                                    <!--[if !mso]><!-->
                                    <a href="${V_GATEWAY_URL}" target="_blank"
                                       style="display:inline-block;background-color:#0C66E4;color:#FFFFFF;font-size:15px;font-weight:600;text-decoration:none;padding:13px 28px;border-radius:6px">
                                        Partner relationship management gateway
                                    </a>
                                    <!--<![endif]-->
                                </td>
                            </tr>
                        </table>

                    </td>
                </tr>

                <!-- Support strip -->
                <tr>
                    <td class="pad" style="padding:24px 40px 0">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <#if V_TENANT_PHONE?? && V_TENANT_PHONE != "Missed">
                                    <td align="left" style="font-size:13px;color:#44546F;padding:6px 0">
                                        <a href="tel:${V_TENANT_PHONE}" style="color:#44546F;text-decoration:none">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                 xmlns="http://www.w3.org/2000/svg"
                                                 style="vertical-align:-2px;margin-right:6px" aria-hidden="true">
                                                <path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11 11 0 0 0 3.4.55 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11 11 0 0 0 .55 3.4 1 1 0 0 1-.25 1L6.6 10.8Z"
                                                      stroke="#626F86" stroke-width="1.5" stroke-linejoin="round"/>
                                            </svg>${V_TENANT_PHONE}
                                        </a>
                                    </td>
                                </#if>
                                <#if V_TENANT_EMAIL?? && V_TENANT_EMAIL != "Missed">
                                    <td align="right" style="font-size:13px;color:#44546F;padding:6px 0">
                                        <a href="mailto:${V_TENANT_EMAIL}" style="color:#44546F;text-decoration:none">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                 xmlns="http://www.w3.org/2000/svg"
                                                 style="vertical-align:-2px;margin-right:6px" aria-hidden="true">
                                                <rect x="3" y="5" width="18" height="14" rx="2" stroke="#626F86"
                                                      stroke-width="1.5"/>
                                                <path d="m3.5 6 8.5 6 8.5-6" stroke="#626F86" stroke-width="1.5"
                                                      stroke-linecap="round" stroke-linejoin="round"/>
                                            </svg>${V_TENANT_EMAIL}
                                        </a>
                                    </td>
                                </#if>
                            </tr>
                        </table>
                    </td>
                </tr>

                <#if (V_TENANT_FACEBOOK?? && V_TENANT_FACEBOOK != "Missed") || (V_TENANT_LINKEDIN?? && V_TENANT_LINKEDIN != "Missed") || (V_TENANT_XING?? && V_TENANT_XING != "Missed")>
                    <!-- Social row -->
                    <tr>
                        <td align="center" style="padding:20px 12px 0">
                            <table role="presentation" cellpadding="0" cellspacing="0">
                                <tr>
                                    <#if V_TENANT_FACEBOOK?? && V_TENANT_FACEBOOK != "Missed">
                                        <td style="padding:0 6px">
                                            <a href="${V_TENANT_FACEBOOK}" target="_blank"
                                               style="display:inline-block;width:32px;height:32px;background-color:#172B4D;border-radius:16px;text-decoration:none">
                                                <table role="presentation" width="32" height="32" cellpadding="0"
                                                       cellspacing="0">
                                                    <tr>
                                                        <td align="center" valign="middle">
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                                 xmlns="http://www.w3.org/2000/svg"
                                                                 aria-label="Facebook">
                                                                <path d="M15 8.5h2V5h-2c-2 0-3.5 1.6-3.5 3.5V11H9v3h2.5v6H14v-6h2l.5-3H14V8.5c0-.3.2-.5.5-.5Z"
                                                                      fill="#FFFFFF"/>
                                                            </svg>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </a>
                                        </td>
                                    </#if>
                                    <#if V_TENANT_LINKEDIN?? && V_TENANT_LINKEDIN != "Missed">
                                        <td style="padding:0 6px">
                                            <a href="${V_TENANT_LINKEDIN}" target="_blank"
                                               style="display:inline-block;width:32px;height:32px;background-color:#172B4D;border-radius:16px;text-decoration:none">
                                                <table role="presentation" width="32" height="32" cellpadding="0"
                                                       cellspacing="0">
                                                    <tr>
                                                        <td align="center" valign="middle">
                                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                                 xmlns="http://www.w3.org/2000/svg"
                                                                 aria-label="LinkedIn">
                                                                <rect x="4" y="9" width="3" height="10" fill="#FFFFFF"/>
                                                                <circle cx="5.5" cy="5.5" r="1.8" fill="#FFFFFF"/>
                                                                <path d="M10.5 9h3v1.6c.6-1 1.7-1.8 3.2-1.8 2.4 0 3.8 1.6 3.8 4.6V19h-3v-5.2c0-1.3-.5-2.2-1.7-2.2-1 0-1.6.7-1.8 1.3-.1.2-.1.6-.1.9V19h-3.4V9Z"
                                                                      fill="#FFFFFF"/>
                                                            </svg>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </a>
                                        </td>
                                    </#if>
                                    <#if V_TENANT_XING?? && V_TENANT_XING != "Missed">
                                        <td style="padding:0 6px">
                                            <a href="${V_TENANT_XING}" target="_blank"
                                               style="display:inline-block;width:32px;height:32px;background-color:#172B4D;border-radius:16px;text-decoration:none">
                                                <table role="presentation" width="32" height="32" cellpadding="0"
                                                       cellspacing="0">
                                                    <tr>
                                                        <td align="center" valign="middle">
                                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                                                 xmlns="http://www.w3.org/2000/svg" aria-label="X">
                                                                <path d="M4 4l16 16M20 4 4 20" stroke="#FFFFFF"
                                                                      stroke-width="2.2" stroke-linecap="round"/>
                                                            </svg>
                                                        </td>
                                                    </tr>
                                                </table>
                                            </a>
                                        </td>
                                    </#if>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </#if>

                <!-- Footer -->
                <tr>
                    <td align="center" style="padding:20px 12px 12px;font-size:12px;line-height:18px;color:#8590A2">
                        <#if V_TENANT_ADDRESS?? && V_TENANT_ADDRESS != "Missed">${V_TENANT_ADDRESS}<br></#if>
                        This is an automated message, please don't reply directly to this email.
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
